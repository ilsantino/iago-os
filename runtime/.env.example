# iaGO v2 daemon — Telegram control surface configuration
#
# Copy this file to `runtime/.env` (gitignored) and fill in real values
# OR export the vars from your shell / systemd unit before starting the
# daemon. NEVER commit the real .env. NEVER paste the bot token into
# logs, chat, or commits.

# Bot token from BotFather (https://t.me/BotFather): `/newbot` -> record token
IAGO_TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram user IDs allowed to send commands.
# Find your ID with @userinfobot. MUST be non-empty -- the daemon refuses
# to start with an empty allowlist.
IAGO_TELEGRAM_ALLOWED_USER_IDS=

# Optional override for the chat that `sendApprovalRequest` broadcasts
# to. If unset, the first entry in IAGO_TELEGRAM_ALLOWED_USER_IDS is
# used (the typical case where the allowed user's private chat is also
# the notification chat).
IAGO_TELEGRAM_CHAT_ID=

# ----- Token rotation procedure -----
# If the token leaks (logged accidentally, committed, shared):
# 1. Open BotFather: /token or /revoke -> get a new token.
# 2. Update IAGO_TELEGRAM_BOT_TOKEN in the live environment.
# 3. Restart the daemon (`systemctl restart iago-daemon` on VPS).
# 4. Audit telemetry NDJSON + journald for the leaked-token window.
