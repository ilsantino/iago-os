{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": ".",
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["agent-runtime/**/*.ts", "daemon/**/*.ts", "telegram/**/*.ts"],
	"exclude": ["dist", "node_modules", "**/*.test.ts"]
}
