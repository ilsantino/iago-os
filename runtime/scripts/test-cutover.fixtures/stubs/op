#!/usr/bin/env bash
# Stub: op (1Password CLI). Always succeeds for whoami/signin, returns a
# fixed 46-byte token for `read` so:
#   (a) provision-credentials.sh's local-vs-remote length round-trip matches
#       the tailscale stub's `systemd-creds decrypt` length (also 46), and
#   (b) cutover.sh T+05 verification's I-1A `len >= 40` threshold passes.
# Real Telegram bot tokens are 46+ chars (<digits>:<35-char alphanumeric>).
STUB_LOG="${STUB_LOG:-}"
if [[ -n "$STUB_LOG" ]]; then
  printf 'op %s\n' "$*" >> "$STUB_LOG"
fi
case "$1" in
  whoami)
    echo "stub-user"
    exit 0
    ;;
  read)
    # 46 bytes: "STUBTOK46BYTES" + ":" + 31 chars padding = 46
    printf 'STUBTOK46BYTES:____________________padding__xx'
    exit 0
    ;;
  signin)
    echo "stub-session"
    exit 0
    ;;
  *)
    exit 0
    ;;
esac
