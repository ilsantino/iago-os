# iaGO-OS runtime state (session-specific, machine-specific) — README is tracked
.iago/state/*
!.iago/state/README.md

# Claude Code local settings (per-developer)
.claude/settings.local.json

# Local overrides (per-developer)
*.local.md

# Environment variables
.env
.env.*

# OS artifacts
.DS_Store
Thumbs.db

# Node
node_modules/

# Local client projects (not part of iaGO-OS distribution)
clients/

# Hook/scheduler runtime locks (machine-specific)
.claude/*.lock
.iago/state/pipeline-runs/

# Pipeline run logs (debug artifacts, not source)
.iago/pipeline-*.log

# Drop dirs may contain embedded repos
docs/research/_drop-*/

# Pipeline run logs (relocated 2026-05-15 to .iago/logs/)
.iago/logs/*.log
!.iago/logs/README.md

# Pipeline review scratch (transient — review session writes, summary preserves the verdict)
.iago/tmp-*.txt
.iago/tmp-*.md
.iago/pipeline-runs/

# Agent transient worktrees (created by Agent tool isolation=worktree; auto-cleaned but admin dirs may linger on Windows)
.claude/worktrees/
