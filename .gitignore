# iaGO-OS runtime state (session-specific, machine-specific)
.iago/state/

# Claude Code local settings (per-developer)
.claude/settings.local.json

# Local overrides (per-developer)
*.local.md

# Environment variables
.env
.env.*

# OS artifacts
.DS_Store
Thumbs.db

# Node
node_modules/

# Local client projects (not part of iaGO-OS distribution)
clients/

# Hook/scheduler runtime locks (machine-specific)
.claude/*.lock
.iago/state/pipeline-runs/

# Pipeline run logs (debug artifacts, not source)
.iago/pipeline-*.log

# Drop dirs may contain embedded repos
docs/research/_drop-*/
