+++	echo "ERROR: age decryption with bogus identity returned unexpected response (rc=$PROBE_RC)" >&2
+++	echo "       output: $PROBE_OUT" >&2
+++	echo "       pubkey at $PUBKEY may be wrong-but-valid; encrypted archive may be unrecoverable" >&2
