+++# ───────────────────────────── Setup ─────────────────────────────
+++
+++setup() {
+++	SUT_SRC="$BATS_TEST_DIRNAME/archive-openclaw.sh"
+++	TMPDIR_TEST=$(mktemp -d -t iago-archive.XXXXXX)
