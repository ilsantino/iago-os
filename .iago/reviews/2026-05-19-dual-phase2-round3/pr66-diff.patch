+++	echo "ERROR: must run as root (sudo bash $0)" >&2
+++	exit 1
+++fi
+++
+++# age is the encryption tool — abort early if missing.
+++if ! command -v age > /dev/null; then
+++	echo "ERROR: 'age' not installed. apt install age (Debian 13 has it in main)" >&2
+++	exit 1
+++fi
