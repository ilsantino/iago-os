+++function toFiveTuple(
+++	xs: ReadonlyArray<string | undefined>,
+++): readonly [string, string, string, string, string] {
+++	const a = xs[0];
+++	const b = xs[1];
+++	const c = xs[2];
+++	const d = xs[3];
+++	const e = xs[4];
+++	if (
+++		a === undefined ||
+++		b === undefined ||
+++		c === undefined ||
+++		d === undefined ||
+++		e === undefined
+++	) {
+++		throw new RangeError("internal: expected 5 cron fields after length check");
+++	}
+++	return [a, b, c, d, e];
+++}
